# ============================================================
# Quote System — environment configuration
# Copy this file to .env and fill in your values.
# Every variable except DATABASE_URL is optional: sensible
# placeholder defaults are used when a value is missing.
# ============================================================

# --- Database (required) ---
# Matches the postgres service in docker-compose.yaml.
DATABASE_URL="postgres://postgres:postgres@localhost:5432/quote-system"

# --- Company identity (shown on quote page, PDF, and email) ---
# Default when unset: "Your Company" (and the row is hidden for empty optional fields)
COMPANY_NAME="Acme Inc."
# Local-language name shown under the main name (e.g. Chinese name). Hidden when empty.
COMPANY_NAME_LOCAL=""
COMPANY_ADDRESS="123 Example Street, Example City"
# VAT / tax registration number. Hidden when empty.
COMPANY_VAT_NUMBER=""
COMPANY_EMAIL="contact@example.com"
COMPANY_PHONE="+1 555 0100"

# --- Bank / payment details (optional) ---
# When all three are empty the whole "Payment Details" section is hidden.
BANK_NAME=""
BANK_ACCOUNT_NAME=""
BANK_ACCOUNT_NUMBER=""

# --- Email sending (optional, via https://resend.com) ---
# Leave RESEND_API_KEY unset to disable the "Send Email" button.
RESEND_API_KEY=""
# Sender display name. Defaults to COMPANY_NAME.
MAIL_SENDER_NAME=""
# Must be a domain verified in Resend. Defaults to onboarding@resend.dev (test only).
MAIL_SENDER_EMAIL=""
# Comma-separated CC list, e.g. "a@example.com,b@example.com"
MAIL_CC_EMAILS=""

# --- Money & locale ---
# ISO 4217 currency code used everywhere amounts are displayed.
CURRENCY="TWD"
# Intl locale used to format money (independent of the UI language).
CURRENCY_LOCALE="zh-TW"
# Default tax rate (%) pre-filled on new quotes. 0-100.
DEFAULT_TAX_RATE="5"
